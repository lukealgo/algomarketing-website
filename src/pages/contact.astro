---
import PageLayout from '../layouts/PageLayout.astro';
import EyebrowLabel from '../components/brand/EyebrowLabel.astro';
import ClientLogoMarquee from '../components/brand/ClientLogoMarquee.astro';
import Reveal from '../components/brand/Reveal.astro';
import data from '../data/pages/contact.yml';
---

<PageLayout title="Contact Us">
  <section class="w-full bg-white pt-32 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Left Column: Form -->
        <Reveal>
        <div>
          <EyebrowLabel class="block mb-2">{data.hero.eyebrow}</EyebrowLabel>
          <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mt-2">{data.hero.heading}</h1>
          <p class="text-neutral-mid mt-4 mb-8">
            {data.hero.body}
          </p>

          <form method="POST" action="/api/contact">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {data.form.fields.map((field) => (
                <div class={field.fullWidth ? 'md:col-span-2' : ''}>
                  <label for={field.id} class="text-sm font-medium text-brand-navy mb-1 block">
                    {field.label} {field.required && <span class="text-red-500">*</span>}
                  </label>
                  <input
                    type={field.type}
                    id={field.id}
                    name={field.name}
                    required={field.required}
                    class="w-full px-6 py-3 rounded-full border border-neutral-light focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/20 transition text-brand-navy"
                  />
                </div>
              ))}

              <!-- Message textarea (full width) -->
              <div class="md:col-span-2">
                <label for={data.form.messageField.id} class="text-sm font-medium text-brand-navy mb-1 block">
                  {data.form.messageField.label}
                </label>
                <textarea
                  id={data.form.messageField.id}
                  name={data.form.messageField.name}
                  rows="4"
                  class="w-full px-6 py-3 rounded-2xl border border-neutral-light focus:border-brand-green focus:outline-none focus:ring-2 focus:ring-brand-green/20 transition text-brand-navy"
                ></textarea>
              </div>
            </div>

            <!-- Checkboxes -->
            <div class="mt-4 space-y-3">
              {data.form.checkboxes.map((checkbox) => (
                <label class="flex items-start gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    name={checkbox.name}
                    class="mt-1 accent-brand-green"
                  />
                  <span class="text-sm text-neutral-mid">
                    {checkbox.label}
                  </span>
                </label>
              ))}
            </div>

            <!-- Submit button -->
            <button
              type="submit"
              class="w-full md:w-auto bg-gradient-cta text-white font-semibold px-8 py-3 rounded-full hover:opacity-90 transition mt-4"
            >
              {data.form.submitText} &rarr;
            </button>
          </form>
        </div>
        </Reveal>

        <!-- Right Column -->
        <Reveal delay={1}>
        <div class="md:sticky md:top-32">
          <div class="rounded-2xl overflow-hidden aspect-[3/4]">
            <img src={data.contactImage.src} alt={data.contactImage.alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="mt-8">
            <p class="text-sm font-medium text-brand-navy mb-4">{data.trustedBy.label}</p>
            <div class="grid grid-cols-3 gap-4">
              {data.trustedBy.clients.map((name) => (
                <span class="font-display text-sm font-semibold text-neutral-mid/50 text-center">
                  {name}
                </span>
              ))}
            </div>
          </div>
        </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Social proof marquee -->
  <Reveal>
  <ClientLogoMarquee />
  </Reveal>
</PageLayout>
