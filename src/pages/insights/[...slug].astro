---
import PageLayout from '../../layouts/PageLayout.astro';
import EyebrowLabel from '../../components/brand/EyebrowLabel.astro';
import CTABanner from '../../components/brand/CTABanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map((insight) => ({
    params: { slug: insight.id },
    props: { insight },
  }));
}

const { insight } = Astro.props;
const { Content } = await render(insight);

const allInsights = await getCollection('insights');
const related = allInsights
  .filter((i) => i.id !== insight.id)
  .slice(0, 3);
---

<PageLayout title={insight.data.title} description={insight.data.excerpt}>
  <!-- Article Header -->
  <section class="pt-32 pb-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-xs font-semibold uppercase tracking-wider text-brand-green bg-brand-green/10 px-3 py-1 rounded-full">
          {insight.data.category}
        </span>
        <span class="text-sm text-neutral-mid">
          {insight.data.publishedDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-brand-navy leading-tight">
        {insight.data.title}
      </h1>
      <p class="text-xl text-neutral-mid mt-6">
        {insight.data.excerpt}
      </p>
      <div class="flex items-center gap-3 mt-8 pt-8 border-t border-neutral-light">
        <div class="w-10 h-10 rounded-full bg-brand-green/10 flex items-center justify-center">
          <span class="text-brand-green font-semibold text-sm">AM</span>
        </div>
        <div>
          <p class="text-sm font-semibold text-brand-navy">{insight.data.author}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="pb-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none prose-headings:text-brand-navy prose-headings:font-bold prose-p:text-neutral-dark prose-strong:text-brand-navy prose-a:text-brand-green prose-a:no-underline hover:prose-a:underline prose-li:text-neutral-dark">
        <Content />
      </article>
    </div>
  </section>

  <!-- Related Articles -->
  {related.length > 0 && (
    <section class="py-16 bg-surface-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-brand-navy mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {related.map((article) => (
            <a href={`/insights/${article.id}`} class="block group">
              <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition">
                <div class="p-6">
                  <span class="text-xs font-semibold uppercase tracking-wider text-brand-green">
                    {article.data.category}
                  </span>
                  <h3 class="text-lg font-bold text-brand-navy mt-2 group-hover:text-brand-green transition">
                    {article.data.title}
                  </h3>
                  <p class="text-neutral-mid text-sm mt-2 line-clamp-2">
                    {article.data.excerpt}
                  </p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABanner subtext="Deploy AI-fluent marketing specialists into your team today.">
    Ready to Transform Your Marketing Execution?
  </CTABanner>
</PageLayout>
