---
import PageLayout from '../layouts/PageLayout.astro';
import GradientSection from '../components/brand/GradientSection.astro';
import SectionHeading from '../components/brand/SectionHeading.astro';
import EyebrowLabel from '../components/brand/EyebrowLabel.astro';
import OrbitalGraphic from '../components/brand/OrbitalGraphic.astro';
import StatCard from '../components/brand/StatCard.astro';
import CTABanner from '../components/brand/CTABanner.astro';
import Reveal from '../components/brand/Reveal.astro';
import data from '../data/pages/about.yml';
---

<PageLayout title="About Us">
  <!-- Hero -->
  <GradientSection variant="hero">
    <div class="relative flex flex-col items-center text-center py-16 md:py-24">
      <OrbitalGraphic size="lg" class="top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" />
      <div class="relative z-10">
        <EyebrowLabel class="text-white mb-4 block">{data.hero.eyebrow}</EyebrowLabel>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">{data.hero.heading}</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto text-center">
          {data.hero.body}
        </p>
      </div>
    </div>
  </GradientSection>

  <!-- Our Story -->
  <section class="w-full bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Reveal>
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <Reveal>
            <div>
              <SectionHeading align="left" eyebrow={data.story.eyebrow}>
                {data.story.heading}
              </SectionHeading>
              <div class="mt-6 space-y-4 text-neutral-mid">
                {data.story.paragraphs.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
            </div>
          </Reveal>
          <Reveal delay={1}>
            <div class="rounded-2xl bg-surface-green aspect-square flex items-center justify-center overflow-hidden relative">
              <img src="/images/hero-abstract.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" />
            </div>
          </Reveal>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Founder Section -->
  <section class="w-full bg-surface-green py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <Reveal>
          <div class="flex justify-center">
            <div class="rounded-full w-64 h-64 overflow-hidden">
              <img src={data.founder.photo} alt={`${data.founder.name}, ${data.founder.title} of AlgoMarketing`} class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
        </Reveal>
        <Reveal delay={1}>
          <div>
            <EyebrowLabel class="mb-3 block">{data.founder.eyebrow}</EyebrowLabel>
            <h2 class="text-3xl font-bold text-brand-navy">{data.founder.name}</h2>
            <p class="text-brand-green font-semibold mt-1 mb-6">{data.founder.title}</p>
            <div class="space-y-4 text-neutral-mid">
              {data.founder.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="w-full bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow={data.timeline.eyebrow}>
        {data.timeline.heading}
      </SectionHeading>

      <div class="relative border-l-2 border-brand-green ml-4 md:ml-0 md:mx-auto md:max-w-2xl mt-12">
        {data.timeline.entries.map((entry, i) => (
          <Reveal delay={i}>
            <div class="relative pl-8 pb-10 last:pb-0">
              <div class="absolute w-4 h-4 rounded-full bg-brand-green -left-[9px] top-1"></div>
              <p class="font-bold text-brand-green text-xl">{entry.year}</p>
              <p class="text-neutral-mid mt-1">{entry.description}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Diversity Section -->
  <GradientSection variant="primary">
    <Reveal>
      <h2 class="text-white text-3xl md:text-4xl font-bold text-center mb-12">{data.diversity.heading}</h2>
    </Reveal>
    <Reveal delay={1}>
      <div class="grid md:grid-cols-3 gap-6">
        {data.diversity.stats.map((stat) => (
          <StatCard value={stat.value} label={stat.label} animate />
        ))}
      </div>
    </Reveal>
  </GradientSection>

  <!-- How We Work -->
  <section class="w-full bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow={data.process.eyebrow}>
        {data.process.heading}
      </SectionHeading>

      <div class="grid md:grid-cols-4 gap-8 mt-12">
        {data.process.steps.map((step, i) => (
          <Reveal delay={i}>
            <div class="text-center">
              <span class="text-5xl font-bold text-brand-green">{step.number}</span>
              <h3 class="font-semibold text-brand-navy mt-4">{step.title}</h3>
              <p class="text-neutral-mid text-sm mt-2">{step.description}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <Reveal>
    <CTABanner>
      {data.cta.heading}
    </CTABanner>
  </Reveal>
</PageLayout>
