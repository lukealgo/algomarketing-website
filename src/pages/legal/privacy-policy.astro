---
import PageLayout from '../../layouts/PageLayout.astro';
import { marked } from 'marked';
import data from '../../data/pages/privacy-policy.yml';

const htmlContent = marked(data.body);
---

<PageLayout title={data.title}>
  <section class="pt-32 pb-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-8">{data.title}</h1>
      <div class="prose prose-lg max-w-none prose-headings:text-brand-navy prose-p:text-neutral-dark" set:html={htmlContent} />
    </div>
  </section>
</PageLayout>
