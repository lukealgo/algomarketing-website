---
import PageLayout from '../layouts/PageLayout.astro';
import data from '../data/pages/404.yml';
---

<PageLayout title="Page Not Found">
  <section class="min-h-[70vh] flex items-center justify-center bg-surface-mint">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-8xl font-bold text-brand-green/20 mb-4">404</div>
      <h1 class="text-3xl md:text-4xl font-bold text-brand-navy">
        {data.heading}
      </h1>
      <p class="text-neutral-mid text-lg mt-6">
        {data.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href={data.primaryButton.link} class="bg-gradient-cta text-white font-semibold px-8 py-3 rounded-full hover:opacity-90 transition">
          {data.primaryButton.text}
        </a>
        <a href={data.secondaryButton.link} class="border-2 border-brand-navy text-brand-navy font-semibold px-8 py-3 rounded-full hover:bg-brand-navy hover:text-white transition">
          {data.secondaryButton.text}
        </a>
      </div>
      <div class="mt-12 pt-8 border-t border-neutral-light">
        <p class="text-sm text-neutral-mid mb-4">{data.popularPages.label}</p>
        <div class="flex flex-wrap justify-center gap-4">
          {data.popularPages.links.map((link: { text: string; href: string }) => (
            <a href={link.href} class="text-brand-green hover:underline text-sm">{link.text}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</PageLayout>
