---
interface Props {
  variant?: 'color' | 'white';
  class?: string;
}

const { variant = 'color', class: className } = Astro.props;
---

<a
  href="/"
  class:list={[
    'inline-flex items-center font-display text-2xl font-semibold tracking-tight select-none',
    className,
  ]}
  aria-label="AlgoMarketing - Home"
>
  {variant === 'color' ? (
    <>
      <span class="text-gradient-brand">algo</span><span class="text-brand-navy">marketing</span>
    </>
  ) : (
    <span class="text-white">algomarketing</span>
  )}
</a>
