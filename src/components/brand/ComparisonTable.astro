---
import Reveal from './Reveal.astro';
import data from '../../data/shared/comparison-table.yml';

const rows = data.rows;
---

<!-- Desktop table -->
<div class="comparison-table-wrapper hidden md:block">
  <div class="overflow-hidden rounded-2xl border border-neutral-light shadow-sm">
    <table class="w-full border-collapse text-left">
      <thead>
        <tr>
          <th class="bg-surface-gray px-6 py-5 text-sm font-semibold text-neutral-mid uppercase tracking-wider w-[22%]">
            Criteria
          </th>
          <th class="bg-surface-gray px-6 py-5 text-sm font-semibold text-neutral-mid uppercase tracking-wider text-center w-[26%]">
            Staffing Agencies
          </th>
          <th class="bg-surface-gray px-6 py-5 text-sm font-semibold text-neutral-mid uppercase tracking-wider text-center w-[26%]">
            Freelancer Platforms
          </th>
          <th class="px-6 py-5 text-sm font-bold text-white uppercase tracking-wider text-center w-[26%] bg-gradient-primary">
            AlgoMarketing
          </th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <Reveal delay={i + 1} tag="tr" class={`border-t border-neutral-light ${i % 2 === 0 ? 'bg-white' : 'bg-surface-gray/50'}`}>
            <td class="px-6 py-4 font-semibold text-brand-navy text-sm">
              {row.criteria}
            </td>
            <td class="px-6 py-4 text-neutral-mid text-sm text-center">
              <span class="inline-flex items-center gap-1.5">
                <span class="text-brand-pink font-bold text-base">&#x2717;</span>
                {row.agency}
              </span>
            </td>
            <td class="px-6 py-4 text-neutral-mid text-sm text-center">
              <span class="inline-flex items-center gap-1.5">
                <span class="text-brand-orange font-bold text-base">&#x2717;</span>
                {row.freelancer}
              </span>
            </td>
            <td class="px-6 py-4 text-brand-navy text-sm text-center font-medium algo-col">
              <span class="inline-flex items-center gap-1.5">
                <span class="text-brand-green font-bold text-base">&#x2713;</span>
                {row.algo}
              </span>
            </td>
          </Reveal>
        ))}
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile stacked cards -->
<div class="comparison-table-mobile md:hidden space-y-6">
  {rows.map((row, i) => (
    <Reveal delay={i + 1}>
      <div class="rounded-xl border border-neutral-light overflow-hidden shadow-sm">
        <div class="bg-surface-gray px-5 py-3">
          <h3 class="font-semibold text-brand-navy text-sm">{row.criteria}</h3>
        </div>
        <div class="divide-y divide-neutral-light">
          <div class="px-5 py-3 flex items-start justify-between gap-3">
            <span class="text-xs font-semibold text-neutral-mid uppercase tracking-wide shrink-0">Staffing Agencies</span>
            <span class="text-sm text-neutral-mid text-right flex items-center gap-1.5">
              <span class="text-brand-pink font-bold">&#x2717;</span>
              {row.agency}
            </span>
          </div>
          <div class="px-5 py-3 flex items-start justify-between gap-3">
            <span class="text-xs font-semibold text-neutral-mid uppercase tracking-wide shrink-0">Freelancer Platforms</span>
            <span class="text-sm text-neutral-mid text-right flex items-center gap-1.5">
              <span class="text-brand-orange font-bold">&#x2717;</span>
              {row.freelancer}
            </span>
          </div>
          <div class="px-5 py-3 flex items-start justify-between gap-3 bg-brand-green/5 border-l-4 border-brand-green">
            <span class="text-xs font-bold text-brand-navy uppercase tracking-wide shrink-0">AlgoMarketing</span>
            <span class="text-sm text-brand-navy font-medium text-right flex items-center gap-1.5">
              <span class="text-brand-green font-bold">&#x2713;</span>
              {row.algo}
            </span>
          </div>
        </div>
      </div>
    </Reveal>
  ))}
</div>

<style>
  .algo-col {
    background-color: rgba(31, 224, 191, 0.06);
    position: relative;
  }

  thead th:last-child {
    position: relative;
  }

  /* Subtle left border on AlgoMarketing column */
  .algo-col::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-brand-green);
  }
</style>
