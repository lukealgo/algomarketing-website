---
interface Props {
  delay?: number;
  class?: string;
  tag?: string;
}

const { delay = 0, class: className = '', tag = 'div' } = Astro.props;
const Tag = tag as any;
---

<Tag
  data-reveal
  class:list={['reveal', className]}
  style={delay ? `--reveal-delay: ${delay * 75}ms` : undefined}
>
  <slot />
</Tag>
