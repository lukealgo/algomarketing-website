---
import Logo from './Logo.astro';
---

<footer class="bg-brand-navy text-white">
  <!-- Footer links -->
  <div class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Solutions -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">Solutions</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/solutions/embedded-talent" class="text-sm text-white/80 transition-colors hover:text-white">
              Embedded Talent
            </a>
          </li>
          <li>
            <a href="/solutions/ai-workflow-transformation" class="text-sm text-white/80 transition-colors hover:text-white">
              AI Workflow Transformation
            </a>
          </li>
          <li>
            <a href="/solutions/marketing-operations" class="text-sm text-white/80 transition-colors hover:text-white">
              Marketing Operations
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">Company</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/about" class="text-sm text-white/80 transition-colors hover:text-white">
              About
            </a>
          </li>
          <li>
            <a href="/case-studies" class="text-sm text-white/80 transition-colors hover:text-white">
              Case Studies
            </a>
          </li>
          <li>
            <a href="/insights" class="text-sm text-white/80 transition-colors hover:text-white">
              Insights
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">Resources</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/blog" class="text-sm text-white/80 transition-colors hover:text-white">
              Blog
            </a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-white/80 transition-colors hover:text-white">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/50">Legal</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/privacy" class="text-sm text-white/80 transition-colors hover:text-white">
              Privacy Policy
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-6 py-8">
      <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
        <!-- Logo -->
        <Logo variant="white" />

        <!-- Social links -->
        <div class="flex items-center gap-4">
          <a
            href="#"
            aria-label="LinkedIn"
            class="text-white/60 transition-colors hover:text-white"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="#"
            aria-label="YouTube"
            class="text-white/60 transition-colors hover:text-white"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Company info & copyright -->
      <div class="mt-6 flex flex-col items-center gap-2 text-center text-xs text-white/40 md:flex-row md:justify-between">
        <p>UK Company Registration: 10212066 | UK VAT: GB259152590</p>
        <p>&copy; 2025 AlgoMarketing. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>
