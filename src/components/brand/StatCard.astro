---
interface Props {
  value: string;
  label: string;
  animate?: boolean;
}

const { value, label, animate = false } = Astro.props;
---

<div class="bg-brand-navy rounded-xl p-6 text-center">
  <p
    class="text-4xl font-bold text-brand-green mb-2"
    {...(animate ? { 'data-counter': value } : {})}
  >
    {value}
  </p>
  <p class="text-sm text-white/70">{label}</p>
</div>
