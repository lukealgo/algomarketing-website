---
import BaseLayout from './BaseLayout.astro';
import Navigation from '../components/brand/Navigation';
import Footer from '../components/brand/Footer.astro';
import StickyMobileCTA from '../components/brand/StickyMobileCTA';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Navigation client:load />
  <main>
    <slot />
  </main>
  <Footer />
  <StickyMobileCTA client:media="(max-width: 768px)" />
</BaseLayout>
